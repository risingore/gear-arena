# --- Secrets ---
# SOUL STRIKE uses no environment variables. No .env template is shipped.
.env
.env.*
*.pem
*.key
*.p12
secrets/

# --- Wavedash CLI local credentials (defensive — usually in ~/.wavedash/) ---
.wavedash/

# --- AI-generated raw assets (pre-processing source files, do not publish) ---
# Heika stores Grok / Suno raw exports here before they are processed by
# Piskel / audio trimming. Only the post-processed versions under
# public/assets/ should ship.
assets-raw/

# Sprite preprocessing intermediates — pre-rembg sources, side-by-side
# comparison renders, and unprocessed raw portraits. Kept on disk for
# future reuse; not shipped (Phaser only loads the post-processed PNGs
# under public/assets/sprites/ and public/assets/images/enemy/).
public/assets/images/alpha/
public/assets/images/rembg-compare/
public/assets/images/indra.jpg

# Windows download alternate-data-stream metadata. Snuck in via WSL
# imports; useless to the build and to git.
*:Zone.Identifier

# --- Kima governance layer (never ship to GitHub) ---
# Any game derived from this template must keep the governance layer out of
# the public repo.
.claude/
CLAUDE.md
.cursorrules
tasks/

# --- Internal working docs (Japanese-authored, not for public consumption) ---
# docs/ contains designer + engineer working documents authored in Japanese.
# The public-facing material (README.md at the repo root) is separate.
docs/*
!docs/devlog.md
!docs/design
docs/design/*
!docs/design/build-spec.md
!docs/screenshots
!docs/screenshots/**
# Media exports: repo stores the 5 stills; GIF / webm live on itch.io only.
docs/screenshots/*.gif
docs/screenshots/*.webm
docs/screenshots/*.mp4

# --- Internal tests (kept private by explicit Heika decision) ---
# The unit tests stay local only. They are not shipped in the public repo.
tests/

# --- Python venv (rembg background removal tool) ---
.venv/

# --- Internal tools (not for public) ---
# All Python utility tools (audio-analyze, youtube-dl, pdf-rotate, etc.)
# are Heika's local workflow and stay out of the public repo.
tools/

# Sprite-preprocessing Python scripts under scripts/ are also Heika's
# local workflow only. The .ts automation scripts (debug-resize,
# browser-test, shots, etc.) stay tracked because they are part of the
# public dev experience; the .py sprite tools are not.
scripts/*.py
scripts/__pycache__/

# --- Node / Bun ---
node_modules/
.cache/

# --- Vite / build output ---
dist/
.vite/
*.tsbuildinfo

# --- Cloudflare Wrangler ---
.wrangler/
.dev.vars

# --- Jam distribution bundles ---
*-itch.zip

# --- Editors / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
nul

# --- Temp files ---
tmp/
*.bak
*.backup
*.swp
*.tmp
*~
*.log
